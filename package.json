{
  "name": "@finografic/md-lint",
  "type": "module",
  "version": "0.16.4",
  "description": "Markdown linter with scoped rule sets for standard and AI agent docs",
  "homepage": "https://github.com/finografic/md-lint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/md-lint.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/md-lint/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://github.com/finografic"
  },
  "license": "MIT",
  "keywords": [
    "finografic",
    "md-lint",
    "genx:type:library",
    "cli",
    "markdown",
    "linter"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "module": "./dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "md-lint": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "styles",
    ".markdownlint.jsonc"
  ],
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsdown --watch",
    "link": "pnpm build && pnpm link --global",
    "unlink": "pnpm unlink --global",
    "build": "tsdown",
    "·········· TESTING": "···················································",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "lint:md": "node dist/cli.mjs",
    "lint:md:fix": "node dist/cli.mjs --fix",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "·········· PUBLISH:GITHUB": "············································",
    "release:github:patch": "pnpm run release:check && pnpm version patch && git push --follow-tags",
    "release:github:minor": "pnpm run release:check && pnpm version minor && git push --follow-tags",
    "release:github:major": "pnpm run release:check && pnpm version major && git push --follow-tags",
    "release:check": "pnpm format:check && pnpm lint:fix && pnpm typecheck && pnpm test:run",
    "release:publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "················································",
    "view:registry:github": "pnpm view @finografic/md-lint --registry=https://npm.pkg.github.com",
    "·········· PACKAGES": "··················································",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest && pnpm update oxfmt --latest && pnpm update oxlint --latest",
    "update:deps:all": "pnpm update --latest",
    "·········· UTILS": "·····················································",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "globby": "^16.2.0",
    "ignore": "^7.0.5",
    "jsonc-parser": "^3.3.1",
    "markdownlint": "^0.40.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@finografic/oxc-config": "^2.3.4",
    "@types/node": "^24.0.0",
    "@types/picomatch": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "node dist/cli.mjs --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
