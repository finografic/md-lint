{
  "name": "@finografic/md-lint",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "description": "Markdown linter with scoped rule sets for standard and AI agent docs",
  "homepage": "https://github.com/finografic/md-lint",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/md-lint.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/md-lint/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": {
    "name": "Justin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://github.com/finografic"
  },
  "license": "MIT",
  "keywords": [
    "finografic",
    "md-lint",
    "genx:type:cli",
    "cli",
    "markdown",
    "linter"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "module": "./dist/index.mjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "md-lint": "./dist/cli.mjs"
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsdown --watch",
    "link": "pnpm build && pnpm link --global",
    "unlink": "pnpm unlink --global",
    "build": "tsdown",
    "·········· TESTING": "···················································",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "·········· LINTING": "···················································",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint.md": "tsx src/cli.ts",
    "lint.md.fix": "tsx src/cli.ts --fix",
    "·········· FORMATTING": "················································",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "·········· PUBLISH:GITHUB": "············································",
    "release:github:patch": "pnpm run release:check && pnpm version patch && git push --follow-tags",
    "release:github:minor": "pnpm run release:check && pnpm version minor && git push --follow-tags",
    "release:github:major": "pnpm run release:check && pnpm version major && git push --follow-tags",
    "release:check": "pnpm format:check && pnpm lint:fix && pnpm typecheck && pnpm test:run",
    "release:publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "················································",
    "view:registry:github": "pnpm view @finografic/md-lint --registry=https://npm.pkg.github.com",
    "·········· PACKAGES": "··················································",
    "update:eslint-config": "pnpm update @finografic/eslint-config --latest",
    "update:oxfmt-config": "pnpm update @finografic/oxfmt-config --latest && pnpm update oxfmt --latest",
    "upgrade:deps:all": "pnpm update --latest",
    "·········· UTILS": "·····················································",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.2",
    "@finografic/eslint-config": "^9.18.4",
    "@finografic/oxfmt-config": "^1.0.3",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/node": "^24.0.0",
    "@types/picomatch": "^4.0.3",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "9.39.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.43.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "eslint --fix"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "eslint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "dependencies": {
    "globby": "^16.2.0",
    "markdownlint": "^0.40.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4"
  }
}
